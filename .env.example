SMTP_HOST=email-smtp.eu-west-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=digital@digitalautomations.it
REPORT_EMAIL=digital@digitalautomations.it
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
# Secret key (sb_secret_..., formato moderno; rimpiazza la legacy service_role):
# scritture DB server-side (send-report, track-result). MAI esporre al client.
SUPABASE_SECRET_KEY=your-supabase-secret-key
ENCHARGE_WEBHOOK_URL=your-encharge-webhook-url

# --- Dashboard admin (/admin) ---
# Password unica per l'area riservata. Cambiarla invalida le sessioni attive.
ADMIN_PASSWORD=your-admin-password
# Opzionale: chiave separata per firmare il cookie di sessione (HMAC). Se vuota,
# si usa ADMIN_PASSWORD come chiave di firma. Imposta una stringa lunga e casuale
# per disaccoppiare la firma dalla password.
ADMIN_SESSION_SECRET=
